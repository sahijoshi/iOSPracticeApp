# =========================================
# macOS
# =========================================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# =========================================
# Xcode
# =========================================
## Build generated
build/
DerivedData/
*.moved-aside
*.xcscmblueprint
*.xccheckout

## User-specific files (per-developer, never share these)
xcuserdata/
*.xcuserstate
*.xcuserdatad/

## Compatibility with Xcode 8 and earlier
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

## Obj-C/Swift specific
*.hmap

## Playgrounds
timeline.xctimeline
playground.xcworkspace

## App packaging / archives
*.ipa
*.xcarchive
*.dSYM
*.dSYM.zip

## Crash logs
*.crash

# =========================================
# Swift Package Manager
# (for SPM dependencies resolved within the Xcode project)
# =========================================
.build/
.swiftpm/

# Keep Package.resolved committed for reproducible builds —
# do NOT ignore it unless your team prefers floating versions
# Package.resolved

# =========================================
# CocoaPods
# =========================================
# Comment the next line if you DO want to check in Pods/
Pods/

# If using CocoaPods, you'll have a workspace — keep it,
# but ignore its user-specific data
*.xcworkspace/xcuserdata/

# =========================================
# Carthage
# =========================================
Carthage/Build/
# Uncomment if you don't want to commit checked-out source
# Carthage/Checkouts

# =========================================
# fastlane
# =========================================
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/screenshots/screenshots.html
fastlane/test_output/
fastlane/.env
fastlane/.env.*

# =========================================
# Code Injection (InjectionForXcode)
# =========================================
iOSInjectionProject/

# =========================================
# SwiftLint
# =========================================
.swiftlint_cache/

# =========================================
# SwiftGen / Sourcery / R.swift (generated code)
# Uncomment any of these if you regenerate at build time
# and don't want generated files in git
# =========================================
# Generated/Strings.swift
# Generated/Colors.swift
# Generated/Assets.swift
# .sourcery/
# R.generated.swift

# =========================================
# Realm
# =========================================
*.realm
*.realm.lock
*.realm.management/

# =========================================
# CoreData (local SQLite stores)
# =========================================
*.sqlite
*.sqlite-shm
*.sqlite-wal

# =========================================
# Firebase / Google Services
# =========================================
# Most teams commit GoogleService-Info.plist (it's a config
# identifier, not a true secret). Uncomment if you manage
# per-environment configs and don't want them in git:
# GoogleService-Info.plist
firebase-debug.log
.firebase/

# =========================================
# Crashlytics / Fabric
# =========================================
fabric.properties
Crashlytics.framework
Fabric.framework

# =========================================
# Environment / Secrets / API Keys
# =========================================
.env
.env.local
.env.*.local
Secrets.swift
Secrets.plist
*.xcconfig
!Base.xcconfig
!Shared.xcconfig

# =========================================
# Bundler / Ruby (for fastlane, cocoapods)
# =========================================
.bundle/
vendor/bundle/

# =========================================
# Editor / IDE
# =========================================
.vscode/
.idea/
*.swp

# =========================================
# Test / Coverage Reports
# =========================================
*.gcda
*.gcno
*.profdata
*.profraw
coverage/
TestResults/
*.xcresult

# =========================================
# Misc
# =========================================
*.log
*.tmp
*.bak